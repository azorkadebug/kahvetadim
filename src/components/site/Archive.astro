---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrewIcon from '../BrewIcon.astro';
import { useTranslations, archiveCount, archiveDescription, type Lang } from '../../i18n/ui';
import { formatDate, tastingLang, tastingSlug, tastingUrl, localizePath } from '../../i18n/utils';

interface Props {
  locale: Lang;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('tadimlar', (e) => tastingLang(e.id) === locale);
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const otherLang: Lang = locale === 'tr' ? 'en' : 'tr';
const altUrl = localizePath(otherLang, '/tadimlar/');
---

<BaseLayout
  title={`${t('archive.title')} — ${t('site.name')}`}
  description={archiveDescription(locale, sorted.length)}
  locale={locale}
  altUrl={altUrl}
>
  <section class="py-8 md:py-12 border-b border-[var(--color-line)]">
    <p class="font-sans text-xs uppercase tracking-[0.2em] text-[var(--color-ink-soft)]">{t('archive.kicker')}</p>
    <h1 class="mt-3 font-serif text-4xl md:text-5xl">{t('archive.title')}</h1>
    <p class="mt-4 text-[var(--color-ink-soft)] font-serif">{archiveCount(locale, sorted.length)}.</p>
  </section>

  <section class="py-12">
    {sorted.length === 0 ? (
      <p class="font-serif italic text-[var(--color-ink-soft)]">{t('archive.empty')}</p>
    ) : (
      <table class="w-full font-sans text-sm">
        <thead class="text-xs uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">
          <tr class="border-b border-[var(--color-line)]">
            <th class="text-left py-3 pr-4">{t('archive.th.date')}</th>
            <th class="text-left py-3 pr-4">{t('archive.th.coffee')}</th>
            <th class="text-left py-3 pr-4 hidden sm:table-cell">{t('archive.th.origin')}</th>
            <th class="text-left py-3 pr-4 hidden md:table-cell">{t('archive.th.process')}</th>
            <th class="text-left py-3 pr-4 hidden md:table-cell">{t('archive.th.brew')}</th>
            <th class="text-right py-3">{t('archive.th.score')}</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((entry) => {
            const tdata = entry.data;
            return (
              <tr class="border-b border-[var(--color-line)] hover:bg-[var(--color-bg-soft)]/50">
                <td class="py-4 pr-4 text-[var(--color-ink-soft)] whitespace-nowrap">{formatDate(locale, tdata.date, { day: 'numeric', month: 'short', year: 'numeric' })}</td>
                <td class="py-4 pr-4">
                  <a href={tastingUrl(locale, tastingSlug(entry.id))} class="font-serif text-lg hover:text-[var(--color-accent)]">{tdata.title}</a>
                  <div class="text-xs text-[var(--color-ink-soft)]">{tdata.coffee.roaster}</div>
                </td>
                <td class="py-4 pr-4 hidden sm:table-cell">{tdata.coffee.origin}</td>
                <td class="py-4 pr-4 hidden md:table-cell">{t(`process.${tdata.coffee.process}` as const)}</td>
                <td class="py-4 pr-4 hidden md:table-cell">
                  <span class="inline-flex items-center gap-2">
                    <BrewIcon method={tdata.brew.method} size={18} class="text-[var(--color-accent)]" />
                    {tdata.brew.method}
                  </span>
                </td>
                <td class="py-4 text-right font-medium text-[var(--color-accent)]">{tdata.rating.overall}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </section>
</BaseLayout>
