---
interface Props {
  method: string;
  size?: number;
  class?: string;
}
const { method, size = 18, class: className = '' } = Astro.props;

const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': 1.5,
  'stroke-linejoin': 'round',
  'stroke-linecap': 'round',
};
---

{method === 'V60' && (
  <svg {...common} class={className} aria-label="V60">
    <path d="M5 5 L12 20 L19 5 Z" />
    <line x1="9" y1="5" x2="11" y2="20" />
    <line x1="15" y1="5" x2="13" y2="20" />
    <line x1="13" y1="5" x2="12" y2="20" />
  </svg>
)}

{method === 'Chemex' && (
  <svg {...common} class={className} aria-label="Chemex">
    <path d="M6 3 L10 11 L10 13 L6 21 L18 21 L14 13 L14 11 L18 3 Z" />
    <rect x="9" y="10" width="6" height="3.5" />
    <line x1="15" y1="11.5" x2="17" y2="11.5" />
  </svg>
)}

{method === 'AeroPress' && (
  <svg {...common} class={className} aria-label="AeroPress">
    <rect x="7" y="8" width="10" height="13" rx="1" />
    <line x1="10" y1="8" x2="10" y2="3" />
    <line x1="14" y1="8" x2="14" y2="3" />
    <rect x="8.5" y="2" width="7" height="2" rx="0.5" fill="currentColor" fill-opacity="0.15" />
  </svg>
)}

{method === 'Espresso' && (
  <svg {...common} class={className} aria-label="Espresso">
    <path d="M7 8 L8 17 L16 17 L17 8 Z" />
    <path d="M17 10 Q20 10 20 13 Q20 15 17 15" />
    <line x1="4" y1="20" x2="20" y2="20" />
    <path d="M10 5 Q11 6 10 7" />
    <path d="M13 5 Q14 6 13 7" />
  </svg>
)}

{method === 'French Press' && (
  <svg {...common} class={className} aria-label="French Press">
    <rect x="7" y="8" width="10" height="13" rx="0.5" />
    <path d="M7 8 Q12 4 17 8" />
    <line x1="12" y1="4" x2="12" y2="2" />
    <circle cx="12" cy="1.8" r="1" fill="currentColor" fill-opacity="0.15" />
    <line x1="7" y1="13" x2="17" y2="13" />
  </svg>
)}

{method === 'Moka' && (
  <svg {...common} class={className} aria-label="Moka">
    <path d="M9 3 L15 3 L16 7 L16 13 L8 13 L8 7 Z" />
    <path d="M8 13 L6 20 L18 20 L16 13" />
    <path d="M16 15 Q20 15 20 18 L16 18" />
    <circle cx="12" cy="4.5" r="0.5" fill="currentColor" />
  </svg>
)}

{method === 'Cold Brew' && (
  <svg {...common} class={className} aria-label="Cold Brew">
    <path d="M8 5 L16 5 L16 7 L17 8 L17 21 L7 21 L7 8 L8 7 Z" />
    <line x1="9" y1="3" x2="15" y2="3" />
    <line x1="8.5" y1="5" x2="15.5" y2="5" />
    <path d="M10 17 Q11 15 12 17 Q13 19 14 17" />
  </svg>
)}

{method === 'Orea' && (
  <svg {...common} class={className} aria-label="Orea">
    <path d="M4 5 L8.5 18 L15.5 18 L20 5 Z" />
    <line x1="8.5" y1="18" x2="15.5" y2="18" stroke-width="2.5" />
    <line x1="8" y1="5" x2="10" y2="18" />
    <line x1="16" y1="5" x2="14" y2="18" />
    <line x1="12" y1="5" x2="12" y2="18" />
  </svg>
)}

{method === 'other' && (
  <svg {...common} class={className} aria-label="Demleme">
    <path d="M6 8 L7 19 Q7.2 20 8 20 L16 20 Q16.8 20 17 19 L18 8 Z" />
    <path d="M18 11 Q21 11 21 14 Q21 17 18 17" />
    <line x1="8" y1="11" x2="16" y2="11" />
  </svg>
)}
