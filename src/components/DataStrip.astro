---
import BrewIcon from './BrewIcon.astro';
import GrinderIcon from './GrinderIcon.astro';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';
import { formatDate } from '../i18n/utils';

interface Props {
  coffee: {
    roaster: string;
    origin: string;
    region?: string;
    process: string;
    roastDate?: Date;
  };
  brew: {
    method: string;
    grindSize?: string;
    ratio?: string;
    time?: string;
  };
  overall: number;
  locale?: Lang;
}

const { coffee, brew, overall, locale = defaultLang } = Astro.props;
const t = useTranslations(locale);

const fmt = (d?: Date) =>
  d ? formatDate(locale, d, { day: 'numeric', month: 'short', year: 'numeric' }) : null;

type Item = { label: string; value: string; icon?: 'brew' | 'grind' };

const items: Item[] = [
  { label: t('data.roaster'), value: coffee.roaster },
  { label: t('data.origin'), value: [coffee.origin, coffee.region].filter(Boolean).join(' · ') },
  { label: t('data.process'), value: t(`process.${coffee.process}` as const) },
  { label: t('data.brew'), value: brew.method, icon: 'brew' },
];
if (brew.grindSize) items.push({ label: t('data.grind'), value: brew.grindSize, icon: 'grind' });
if (brew.ratio) items.push({ label: t('data.ratio'), value: brew.ratio });
if (brew.time) items.push({ label: t('data.time'), value: brew.time });
if (coffee.roastDate) items.push({ label: t('data.roasted'), value: fmt(coffee.roastDate)! });
---

<div class="font-sans border-y border-[var(--color-line)] bg-[var(--color-bg-soft)]/60">
  <div class="flex flex-col md:flex-row">
    <dl class="flex-1 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-4 px-6 py-5">
      {items.map(({ label, value, icon }) => (
        <div>
          <dt class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">{label}</dt>
          <dd class="mt-0.5 text-sm text-[var(--color-ink)] flex items-center gap-2">
            {icon === 'brew' && <BrewIcon method={brew.method} size={20} class="text-[var(--color-accent)] shrink-0" />}
            {icon === 'grind' && <GrinderIcon size={20} class="text-[var(--color-accent)] shrink-0" />}
            <span>{value}</span>
          </dd>
        </div>
      ))}
    </dl>
    <div class="flex items-baseline gap-3 md:flex-col md:items-end md:justify-center md:gap-1 px-6 py-4 md:py-5 border-t md:border-t-0 md:border-l border-[var(--color-line)] md:min-w-[140px]">
      <dt class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">{t('data.score')}</dt>
      <dd class="font-serif text-3xl md:text-4xl text-[var(--color-accent)] leading-none">
        {overall}<span class="text-base text-[var(--color-ink-soft)]">/100</span>
      </dd>
    </div>
  </div>
</div>
