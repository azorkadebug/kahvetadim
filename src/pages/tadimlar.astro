---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BrewIcon from '../components/BrewIcon.astro';

const all = await getCollection('tadimlar');
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' }).format(d);

const processLabel: Record<string, string> = {
  washed: 'Yıkanmış',
  natural: 'Natural',
  honey: 'Honey',
  anaerobic: 'Anaerobik',
  other: 'Diğer',
};
---

<BaseLayout title="Arşiv — Kahve Tadımları">
  <section class="py-8 md:py-12 border-b border-[var(--color-line)]">
    <p class="font-sans text-xs uppercase tracking-[0.2em] text-[var(--color-ink-soft)]">Arşiv</p>
    <h1 class="mt-3 font-serif text-4xl md:text-5xl">Tüm Tadımlar</h1>
    <p class="mt-4 text-[var(--color-ink-soft)] font-serif">{sorted.length} fincan, {sorted.length === 0 ? 'henüz hiç' : 'her biri farklı hikâye'}.</p>
  </section>

  <section class="py-12">
    {sorted.length === 0 ? (
      <p class="font-serif italic text-[var(--color-ink-soft)]">Arşiv henüz boş.</p>
    ) : (
      <table class="w-full font-sans text-sm">
        <thead class="text-xs uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">
          <tr class="border-b border-[var(--color-line)]">
            <th class="text-left py-3 pr-4">Tarih</th>
            <th class="text-left py-3 pr-4">Kahve</th>
            <th class="text-left py-3 pr-4 hidden sm:table-cell">Menşei</th>
            <th class="text-left py-3 pr-4 hidden md:table-cell">Proses</th>
            <th class="text-left py-3 pr-4 hidden md:table-cell">Demleme</th>
            <th class="text-right py-3">Puan</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((t) => (
            <tr class="border-b border-[var(--color-line)] hover:bg-[var(--color-bg-soft)]/50">
              <td class="py-4 pr-4 text-[var(--color-ink-soft)] whitespace-nowrap">{fmt(t.data.date)}</td>
              <td class="py-4 pr-4">
                <a href={`/tadim/${t.id}`} class="font-serif text-lg hover:text-[var(--color-accent)]">{t.data.title}</a>
                <div class="text-xs text-[var(--color-ink-soft)]">{t.data.coffee.roaster}</div>
              </td>
              <td class="py-4 pr-4 hidden sm:table-cell">{t.data.coffee.origin}</td>
              <td class="py-4 pr-4 hidden md:table-cell">{processLabel[t.data.coffee.process] ?? t.data.coffee.process}</td>
              <td class="py-4 pr-4 hidden md:table-cell">
                <span class="inline-flex items-center gap-2">
                  <BrewIcon method={t.data.brew.method} size={18} class="text-[var(--color-accent)]" />
                  {t.data.brew.method}
                </span>
              </td>
              <td class="py-4 text-right font-medium text-[var(--color-accent)]">{t.data.rating.overall}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>
</BaseLayout>
